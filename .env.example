# Copy to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Every variable here is validated by src/lib/env.ts at startup. A missing or
# malformed value fails the build with a message naming the variable, rather
# than surfacing as `undefined` at runtime.

# ---------------------------------------------------------------------------
# M0 — Application
# ---------------------------------------------------------------------------

# Fully-qualified base URL of this deployment.
# Local:      http://localhost:3000
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# M1 — Database (Supabase)
#
# Get both from: Supabase dashboard -> Connect -> ORMs -> Prisma.
# Replace [YOUR-PASSWORD] in BOTH with your database password.
#
# Use an alphanumeric password. Characters like @ % ? break URL parsing
# unless percent-encoded, and getting that subtly wrong is a bad afternoon.
# ---------------------------------------------------------------------------

# Pooled connection, port 6543. Used by the app at runtime — serverless
# functions would exhaust a direct connection pool.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection, port 5432. Used only by the Prisma CLI for migrations,
# which need a session-mode connection that pgbouncer cannot provide.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Added in later milestones — listed so the full surface is visible, but not
# yet read or validated by the application.
#
#   M2  BETTER_AUTH_SECRET    32+ character random string
#   M2  BETTER_AUTH_URL       Must exactly match the deployed origin
#   M2  GOOGLE_CLIENT_ID      Google OAuth credentials
#   M2  GOOGLE_CLIENT_SECRET
#   M3  GROQ_API_KEY          Groq API key (free tier)
# ---------------------------------------------------------------------------
