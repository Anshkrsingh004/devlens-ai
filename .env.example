# Copy to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Every variable here is validated by src/lib/env.ts at startup. A missing or
# malformed value fails the build with a message naming the variable, rather
# than surfacing as `undefined` at runtime.

# ---------------------------------------------------------------------------
# M0 — Application
# ---------------------------------------------------------------------------

# Fully-qualified base URL of this deployment.
# Local:      http://localhost:3000
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Added in later milestones — listed here so the full surface is visible, but
# not yet read or validated by the application.
#
#   M1  DATABASE_URL          Supabase pooled connection (port 6543, ?pgbouncer=true)
#   M1  DIRECT_URL            Supabase direct connection (port 5432, migrations only)
#   M2  BETTER_AUTH_SECRET    32+ character random string
#   M2  BETTER_AUTH_URL       Must exactly match the deployed origin
#   M2  GOOGLE_CLIENT_ID      Google OAuth credentials
#   M2  GOOGLE_CLIENT_SECRET
#   M3  GROQ_API_KEY          Groq API key (free tier)
# ---------------------------------------------------------------------------
