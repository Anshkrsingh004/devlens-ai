// DevLens AI — database schema
//
// Reference: DATABASE.md (tables, indexes, and the reasoning behind each).
//
// Milestone scope: M1 creates the three application tables below. The Better
// Auth tables (`user`, `session`, `account`, `verification`) are generated by
// the Better Auth CLI in M2, and the `userId` foreign keys are added at the
// same time (TASKS.md 2.4). Until then `userId` is an indexed plain column —
// declaring a relation now would reference a table that does not yet exist.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs are NOT declared here. Prisma 7 removed `url`/`directUrl`
// from the schema: the CLI reads its URL from prisma.config.ts, and the
// runtime client receives one from the driver adapter in src/lib/db.ts.
//
// That split is deliberate and preserves the Supabase requirement:
//   - CLI / migrations -> DIRECT_URL  (port 5432, session mode)
//   - App at runtime   -> DATABASE_URL (port 6543, pooled)

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
//
// Database enums rather than strings: validated at the database level,
// self-documenting, and surfaced by Prisma as TypeScript union types, so a
// typo becomes a compile error instead of a row nobody notices for weeks.
// ---------------------------------------------------------------------------

enum Language {
  CPP
  PYTHON
  JAVA
  JAVASCRIPT
  TYPESCRIPT
}

enum SourceType {
  PASTE
  UPLOAD
}

enum ReviewStatus {
  PENDING
  COMPLETED
  FAILED
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum ReviewDepth {
  CONCISE
  BALANCED
  THOROUGH
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// One row per review request. Created BEFORE the AI call so that a dropped
/// connection leaves a recoverable PENDING/FAILED row rather than losing the
/// user's work silently.

model Review {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String       @db.VarChar(120)
  language   Language
  /// Capped at 8,000 characters by a Zod schema shared between client and
  /// server (config/limits.ts). Postgres Text has no practical limit, so the
  /// guarantee lives in the one place both runtimes read.
  sourceCode String       @db.Text
  sourceType SourceType   @default(PASTE)
  status     ReviewStatus @default(PENDING)

  /// The full validated report. Written once, read whole, never partially
  /// queried — so normalising it into 13 tables would add joins and
  /// migrations for no query benefit. Type safety is preserved by parsing it
  /// with ReviewResultSchema on both write and read.
  result Json?

  /// Deliberately denormalised out of `result`. It is the only field we sort
  /// and filter by, and sorting inside a JSON column defeats the index. Both
  /// values are written in the same transaction from the same validated
  /// object, so they cannot drift.
  overallScore Int?

  isFavorite Boolean @default(false)

  /// Error taxonomy code, set when status is FAILED.
  errorCode String? @db.VarChar(64)

  // Observability. Enables prompt/model comparison later with no migration.
  model            String? @db.VarChar(64)
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Every index leads with userId because every query in the application is
  // user-scoped; a composite index serves both the filter and the sort.
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite])
  @@index([userId, status])
}

/// Per-user, per-day quota counter. This is the Redis replacement: an atomic
/// upsert on a unique (userId, date) key is a correct, durable, free counter,
/// and it doubles as the data source for the usage meter.

model DailyUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Date only, no time. Matches Groq's daily reset so the quota is trivially
  /// explainable to the user.
  date DateTime @db.Date

  reviewCount Int @default(0)
  tokensUsed  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Makes the row atomically upsertable and prevents double counting under
  // concurrent requests. This unique constraint is also the only index the
  // table needs — it is always read by exact (userId, date) lookup.
  @@unique([userId, date])
}

/// User settings, 1:1 with the user. Kept separate from Better Auth's `user`
/// table so our schema is not coupled to their code generation.

model UserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme           Theme       @default(SYSTEM)
  defaultLanguage Language    @default(TYPESCRIPT)
  /// Alters prompt verbosity, and therefore token cost.
  reviewDepth     ReviewDepth @default(BALANCED)
  /// Token-saving switch: disabling the refactor section reclaims roughly
  /// 1,500 output tokens, which on an 8,000 TPM budget is the difference
  /// between a large file succeeding and hitting a rate limit.
  includeRefactor Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Application-side relations. Every one cascades on delete, so removing an
  // account removes all of its data — no orphans, and a clean answer to
  // "delete my account" requests.
  reviews    Review[]
  dailyUsage DailyUsage[]
  preference UserPreference?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
